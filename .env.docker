# Local Docker Dev Environment
# Used by: docker compose -f docker-compose.dev.yml up
# Copy this file as .env and adjust if needed

POSTGRES_DB=realestate_crm_dev
POSTGRES_USER=crmuser
POSTGRES_PASSWORD=devpassword

JWT_SECRET=dev_secret_key_for_development_only_must_be_32chars_min

CORS_ALLOWED_ORIGINS=http://localhost:4200

# Email (optional for local dev — leave empty to skip)
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
APP_BASE_URL=http://localhost:4200
